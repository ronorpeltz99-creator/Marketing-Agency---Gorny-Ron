# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
#
# This file lists every environment variable (API key, URL, secret) the
# project needs to run. It's committed to Git so everyone knows what's needed.
#
# DO NOT put real secrets in this file. Real secrets go in .env.local
# (which is gitignored).
#
# SETUP STEPS:
# 1. Copy this file:  cp .env.example .env.local
# 2. Open .env.local in VS Code
# 3. Fill in every value by following docs/platform-accounts.md
# 4. Never commit .env.local to Git. Ever.
#
# FORMAT RULES:
# - No spaces around the = sign
# - No quotes needed unless the value has spaces or special characters
# - Lines starting with # are comments, ignored by the app
# - Variable names are UPPERCASE with underscores
#
# =============================================================================


# =============================================================================
# CORE — Application Settings
# =============================================================================

# The public URL where the app runs.
# In development: http://localhost:3000
# In production: https://your-domain.com (Vercel gives you this after deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment name. Use "development" locally, "production" on Vercel.
NODE_ENV=development


# =============================================================================
# SUPABASE — Database + Auth + Storage
# =============================================================================
# Get these from: https://supabase.com
# 1. Create a project
# 2. Go to Project Settings → API
# 3. Copy the Project URL and the keys below

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — safe to expose in the browser, has limited permissions
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — FULL ADMIN ACCESS. Server-side only. NEVER expose in the browser.
# Used by server actions and background jobs to bypass row-level security when needed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# =============================================================================
# ANTHROPIC — Claude AI (powers all six agents)
# =============================================================================
# Get this from: https://console.anthropic.com
# 1. Create an account
# 2. Go to Settings → API Keys
# 3. Create a new key, copy it

ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# The Claude model to use for agents. Claude Sonnet 4.7 is current default.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929


# =============================================================================
# SHOPIFY — Store creation + product management
# =============================================================================
# Get these from: https://partners.shopify.com
# 1. Create a Shopify Partner account (free, gives you unlimited dev stores)
# 2. In the Partner dashboard, create an app
# 3. Under the app settings, find API credentials

# Your Shopify Partner API key
SHOPIFY_API_KEY=your-shopify-api-key

# Your Shopify Partner API secret
SHOPIFY_API_SECRET=your-shopify-api-secret

# The scopes your app needs (permissions). Don't change unless you know why.
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers

# Your Partner organization ID (for creating new dev stores programmatically)
SHOPIFY_PARTNER_ORG_ID=your-partner-org-id

# Partner API token (different from app API key) — for creating dev stores
SHOPIFY_PARTNER_API_TOKEN=your-partner-api-token


# =============================================================================
# META (Facebook/Instagram) — Ads launcher + monitor
# =============================================================================
# Get these from: https://developers.facebook.com
# 1. Create a Meta Developer account
# 2. Create a new app (type: Business)
# 3. Add the Marketing API product to your app
# 4. In App Settings → Basic, find your App ID and App Secret

# Your Meta App ID
META_APP_ID=your-meta-app-id

# Your Meta App Secret
META_APP_SECRET=your-meta-app-secret

# Long-lived user access token — needed for API calls.
# Generate via Graph API Explorer: https://developers.facebook.com/tools/explorer/
# Select your app, request ads_management + ads_read permissions, generate token,
# then exchange for a long-lived token (see docs/platform-accounts.md).
META_ACCESS_TOKEN=your-long-lived-access-token

# Your Ad Account ID — found in Meta Business Suite → Settings → Ad Accounts.
# Format: act_XXXXXXXXXX (include the "act_" prefix)
META_AD_ACCOUNT_ID=act_your-ad-account-id

# Your Facebook Page ID — the page ads run from.
# Found in Page Settings → About → Page ID
META_PAGE_ID=your-facebook-page-id

# Your Instagram Account ID — for Instagram ad placements.
# Found in Meta Business Suite → Accounts → Instagram Accounts
META_INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# Pixel ID — for tracking conversions on your Shopify store.
# Found in Events Manager → Data Sources → Your Pixel → Settings
META_PIXEL_ID=your-pixel-id


# =============================================================================
# DSERS — AliExpress product import + order fulfillment
# =============================================================================
# Get these from: https://dsers.com
# 1. Create a DSers account and connect it to your Shopify store
# 2. Go to Settings → API / Developer settings
# 3. Generate an API key

# DSers API key
DSERS_API_KEY=your-dsers-api-key

# DSers API secret
DSERS_API_SECRET=your-dsers-api-secret

# Base URL for DSers API (default should work, change only if DSers provides a different endpoint)
DSERS_API_URL=https://api.dsers.com


# =============================================================================
# FAL.AI — AI Creative Generation (images + videos)
# =============================================================================
# Get this from: https://fal.ai
# 1. Create an account
# 2. Go to Dashboard → API Keys
# 3. Create a new key

# Fal.ai API key — used for Seedance 2.0, Nano Banana Pro, Kling 3.1, Veo 3.1, Flux, etc.
FAL_KEY=your-fal-api-key

# Default model to use for image generation (can be overridden per request)
# Options: fal-ai/flux, fal-ai/nano-banana-pro, fal-ai/nano-banana-2, etc.
FAL_DEFAULT_IMAGE_MODEL=fal-ai/flux

# Default model to use for video generation (can be overridden per request)
# Options: fal-ai/seedance-2.0, fal-ai/kling-3.1, fal-ai/veo-3.1, etc.
FAL_DEFAULT_VIDEO_MODEL=fal-ai/seedance-2.0


# =============================================================================
# HIGGSFIELD — Secondary creative finishing layer
# =============================================================================
# Get this from: https://higgsfield.ai
# 1. Create an account
# 2. Go to Settings → API
# 3. Generate a key
#
# NOTE: Higgsfield is used as a secondary layer for cinematic camera moves and VFX.
# Phase 5 bake-off will determine the final mix of Fal vs Higgsfield.

HIGGSFIELD_API_KEY=your-higgsfield-api-key
HIGGSFIELD_API_URL=https://api.higgsfield.ai


# =============================================================================
# TRIGGER.DEV — Background jobs + scheduled tasks
# =============================================================================
# Get these from: https://trigger.dev
# 1. Create an account
# 2. Create a new project
# 3. Go to Project Settings → API Keys

# Trigger.dev API key (server-side)
TRIGGER_API_KEY=your-trigger-api-key

# Trigger.dev API URL (default cloud endpoint, change only for self-hosted)
TRIGGER_API_URL=https://api.trigger.dev

# Trigger.dev project ID
TRIGGER_PROJECT_ID=your-trigger-project-id


# =============================================================================
# DISCORD — Notifications (urgent/actionable alerts)
# =============================================================================
# Get this from: https://discord.com
# 1. Open your Discord server settings
# 2. Go to Integrations → Webhooks
# 3. Create a new webhook for each channel you want alerts in
# 4. Copy the webhook URL

# Webhook URL for the #alerts channel (kill/scale recs, errors, failed fulfillments)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Optional: separate webhook for less urgent updates
DISCORD_WEBHOOK_URL_UPDATES=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token


# =============================================================================
# TELEGRAM — Notifications (redundant critical alerts)
# =============================================================================
# Get these from: https://telegram.org
# 1. Message @BotFather on Telegram
# 2. Create a new bot with /newbot
# 3. Copy the bot token BotFather gives you
# 4. Add the bot to your group chat
# 5. Get the chat ID (see docs/platform-accounts.md for how)

# Telegram Bot token from BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Chat ID where alerts will be sent (group chat or personal chat)
TELEGRAM_CHAT_ID=your-chat-id


# =============================================================================
# STRIPE CONNECT — Payments (v2, skip for now)
# =============================================================================
# These are NOT needed for v1. Leaving them here as placeholders so you know
# they're coming. Don't fill them in yet.

# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
